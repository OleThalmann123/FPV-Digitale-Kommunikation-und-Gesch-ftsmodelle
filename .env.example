# Kopiere diese Datei zu .env.local (lokal) bzw. trage die Werte in Vercel
# unter Project Settings -> Environment Variables ein. .env.local ist
# bereits in .gitignore -- niemals echte Keys committen.

# Supabase (Frontend, daher NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenRouter (server-seitig, fuer GPT-4o Vision + alle openrouter/* Modelle)
OPENROUTER_API_KEY=

# PublicAI / Apertus (server-seitig, optional)
PUBLICAI_API_KEY=
